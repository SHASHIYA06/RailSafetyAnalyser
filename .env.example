# ─── DATABASE (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
PGHOST=ep-xxx.us-east-2.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=username
PGPASSWORD=password

# ─── AI (OpenRouter / Gemini) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxx

# ─── FIREBASE (Authentication) ─────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdefgh

# For backend Firebase Admin (optional - for server-side auth verification)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── APP SETTINGS ──────────────────────────────────────────────────────────────
NODE_ENV=production
SESSION_SECRET=your-super-secret-session-key-change-this

# ─── ADMIN ACCESS ──────────────────────────────────────────────────────────────
# Hardcoded admin passcode (do not change without updating login.tsx)
ADMIN_PASSCODE=9799494321
